{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "target": "es2020",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["vitest/globals"],
    "verbatimModuleSyntax": false
  }
}
