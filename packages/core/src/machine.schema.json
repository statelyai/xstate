{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "XState v6 machine definition (MachineJSON)",
  "description": "The JSON-serializable subset of an XState machine definition, as accepted by createMachineFromConfig and produced by machine.definition / JSON.stringify(machine). Functions appear as { \"@type\": \"code\", \"lang\": \"ts\", \"expr\": ... } code expressions. Actor logic, schemas, and other non-code runtime values appear as { \"$unserializable\": ... } markers; a definition is fully portable iff it contains no markers.",
  "$ref": "#/$defs/machine",
  "$defs": {
    "unserializable": {
      "type": "object",
      "description": "Marker for a value that exists at runtime but cannot be represented as data (inline function, actor logic, runtime schema). Reviving a definition containing markers requires re-providing these implementations.",
      "properties": {
        "$unserializable": {
          "type": "string",
          "enum": ["function", "actor", "schema", "value"]
        },
        "id": { "type": "string" }
      },
      "required": ["$unserializable"],
      "additionalProperties": false
    },
    "codeExpression": {
      "type": "object",
      "description": "Portable source expression for a function-valued machine config field.",
      "properties": {
        "@type": { "const": "code" },
        "lang": { "const": "ts" },
        "expr": { "type": "string" }
      },
      "required": ["@type", "lang", "expr"],
      "additionalProperties": false
    },
    "actionObject": {
      "type": "object",
      "description": "A serialized action: a built-in (@xstate.raise, @xstate.cancel, @xstate.log, @xstate.emit, @xstate.assign), an SCXML executable-content op (scxml.*), or a custom { type, params } action resolved from the machine's named actions.",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/actionObject" },
        { "$ref": "#/$defs/codeExpression" },
        { "$ref": "#/$defs/unserializable" }
      ]
    },
    "actionList": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "guardObject": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "params": { "type": "object" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "transitionObject": {
      "type": "object",
      "properties": {
        "target": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "actions": { "$ref": "#/$defs/actionList" },
        "context": { "type": "object" },
        "guard": {
          "oneOf": [
            { "$ref": "#/$defs/guardObject" },
            { "$ref": "#/$defs/codeExpression" },
            { "$ref": "#/$defs/unserializable" }
          ]
        },
        "to": { "$ref": "#/$defs/unserializable" },
        "input": {},
        "description": { "type": "string" },
        "reenter": { "type": "boolean" },
        "meta": { "type": "object" }
      },
      "additionalProperties": false
    },
    "transition": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/transitionObject" },
        { "$ref": "#/$defs/codeExpression" },
        { "$ref": "#/$defs/unserializable" }
      ]
    },
    "transitionOrArray": {
      "oneOf": [
        { "$ref": "#/$defs/transition" },
        { "type": "array", "items": { "$ref": "#/$defs/transition" } }
      ]
    },
    "transitionMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/transitionOrArray" }
    },
    "invokeObject": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registryKey": { "type": "string" },
        "src": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/$defs/unserializable" }]
        },
        "input": {},
        "onDone": { "$ref": "#/$defs/transitionOrArray" },
        "onError": { "$ref": "#/$defs/transitionOrArray" },
        "onSnapshot": { "$ref": "#/$defs/transitionOrArray" },
        "onTimeout": { "$ref": "#/$defs/transitionOrArray" },
        "timeout": { "$ref": "#/$defs/duration" }
      },
      "required": ["src"],
      "additionalProperties": false
    },
    "invoke": {
      "oneOf": [
        { "$ref": "#/$defs/invokeObject" },
        { "type": "array", "items": { "$ref": "#/$defs/invokeObject" } }
      ]
    },
    "duration": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "string",
          "description": "'250ms', '5s'/'1.5s', or an ISO 8601 duration ('PT1M30S')"
        },
        { "$ref": "#/$defs/codeExpression" },
        { "$ref": "#/$defs/unserializable" }
      ]
    },
    "initial": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "target": { "type": "string" },
            "input": {}
          },
          "required": ["target"],
          "additionalProperties": false
        }
      ]
    },
    "implementationMap": {
      "type": "object",
      "description": "Named implementations. Keys are the contract a revived machine must fulfill (e.g. via provide()); values are usually unserializable markers.",
      "additionalProperties": true
    },
    "stateNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "atomic",
            "compound",
            "parallel",
            "final",
            "history",
            "choice"
          ]
        },
        "initial": { "$ref": "#/$defs/initial" },
        "states": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stateNode" }
        },
        "on": { "$ref": "#/$defs/transitionMap" },
        "after": { "$ref": "#/$defs/transitionMap" },
        "always": { "$ref": "#/$defs/transitionOrArray" },
        "choice": {
          "oneOf": [
            { "$ref": "#/$defs/transition" },
            { "$ref": "#/$defs/codeExpression" },
            { "$ref": "#/$defs/unserializable" }
          ]
        },
        "route": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "description": { "type": "string" },
                "reenter": { "type": "boolean" },
                "meta": { "type": "object" },
                "guard": { "type": "string" },
                "input": { "type": "object" }
              },
              "additionalProperties": false
            },
            { "$ref": "#/$defs/codeExpression" },
            { "$ref": "#/$defs/unserializable" }
          ]
        },
        "invoke": { "$ref": "#/$defs/invoke" },
        "entry": {
          "oneOf": [
            { "$ref": "#/$defs/actionList" },
            { "$ref": "#/$defs/action" }
          ]
        },
        "exit": {
          "oneOf": [
            { "$ref": "#/$defs/actionList" },
            { "$ref": "#/$defs/action" }
          ]
        },
        "timeout": { "$ref": "#/$defs/duration" },
        "onTimeout": { "$ref": "#/$defs/transitionOrArray" },
        "meta": { "type": "object" },
        "description": { "type": "string" },
        "history": { "type": "string", "enum": ["shallow", "deep"] },
        "target": { "type": "string" },
        "output": {},
        "input": {},
        "tags": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "context": {
          "oneOf": [
            { "type": "object" },
            { "$ref": "#/$defs/codeExpression" },
            { "$ref": "#/$defs/unserializable" }
          ]
        },
        "_scxmlDonedata": { "type": "object" },
        "version": { "type": "string" },
        "internalEvents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schemas": { "type": "object" },
        "actions": { "$ref": "#/$defs/implementationMap" },
        "guards": { "$ref": "#/$defs/implementationMap" },
        "actorSources": { "$ref": "#/$defs/implementationMap" },
        "delays": { "$ref": "#/$defs/implementationMap" }
      },
      "additionalProperties": true
    },
    "machine": { "$ref": "#/$defs/stateNode" }
  }
}
