{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "XState v6 machine definition (MachineJSON)",
  "description": "The JSON-serializable XState machine definition accepted by createMachineFromConfig. Expressions use reserved @ keys: @exprLang on the machine and @expr/@code with optional @lang in value slots.",
  "$ref": "#/$defs/machine",
  "$defs": {
    "jsonSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "eventPayloadSchema": {
      "allOf": [
        { "$ref": "#/$defs/jsonSchema" },
        {
          "not": {
            "type": "object",
            "properties": {
              "properties": {
                "type": "object",
                "required": ["type"]
              }
            },
            "required": ["properties"]
          }
        }
      ]
    },
    "expression": {
      "type": "object",
      "properties": {
        "@expr": { "type": "string" },
        "@lang": { "type": "string" }
      },
      "required": ["@expr"],
      "additionalProperties": false
    },
    "code": {
      "type": "object",
      "properties": {
        "@code": { "type": "string" },
        "@lang": { "type": "string" }
      },
      "required": ["@code"],
      "additionalProperties": false
    },
    "resolvable": {
      "oneOf": [{ "$ref": "#/$defs/expression" }, { "$ref": "#/$defs/code" }]
    },
    "condition": {
      "oneOf": [
        { "$ref": "#/$defs/resolvable" },
        { "$ref": "#/$defs/guardObject" }
      ]
    },
    "guardObject": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "params": {}
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "actionObject": {
      "type": "object",
      "properties": {
        "type": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/actionObject" },
        { "$ref": "#/$defs/resolvable" }
      ]
    },
    "actionList": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "transitionObject": {
      "type": "object",
      "properties": {
        "target": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "actions": { "$ref": "#/$defs/actionList" },
        "context": { "type": "object" },
        "guard": { "$ref": "#/$defs/condition" },
        "input": {},
        "description": { "type": "string" },
        "reenter": { "type": "boolean" },
        "meta": { "type": "object" }
      },
      "additionalProperties": false
    },
    "transition": {
      "oneOf": [
        { "$ref": "#/$defs/transitionObject" },
        { "$ref": "#/$defs/resolvable" }
      ]
    },
    "transitionOrArray": {
      "oneOf": [
        { "$ref": "#/$defs/transition" },
        { "type": "array", "items": { "$ref": "#/$defs/transition" } }
      ]
    },
    "transitionMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/transitionOrArray" }
    },
    "choiceBranch": {
      "type": "object",
      "properties": {
        "when": { "$ref": "#/$defs/condition" },
        "target": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "context": { "type": "object" },
        "input": {},
        "description": { "type": "string" },
        "reenter": { "type": "boolean" },
        "meta": { "type": "object" }
      },
      "required": ["target"],
      "additionalProperties": false
    },
    "choice": {
      "oneOf": [
        { "type": "array", "items": { "$ref": "#/$defs/choiceBranch" } },
        { "$ref": "#/$defs/resolvable" }
      ]
    },
    "invokeObject": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registryKey": { "type": "string" },
        "src": { "type": "string" },
        "input": {},
        "onDone": { "$ref": "#/$defs/transitionOrArray" },
        "onError": { "$ref": "#/$defs/transitionOrArray" },
        "onSnapshot": { "$ref": "#/$defs/transitionOrArray" },
        "onTimeout": { "$ref": "#/$defs/transitionOrArray" },
        "timeout": { "$ref": "#/$defs/duration" }
      },
      "required": ["src"],
      "additionalProperties": false
    },
    "invoke": {
      "oneOf": [
        { "$ref": "#/$defs/invokeObject" },
        { "type": "array", "items": { "$ref": "#/$defs/invokeObject" } }
      ]
    },
    "duration": {
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "$ref": "#/$defs/resolvable" }
      ]
    },
    "initial": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "target": { "type": "string" },
            "input": {}
          },
          "required": ["target"],
          "additionalProperties": false
        }
      ]
    },
    "actionDefinitions": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/action" },
          { "$ref": "#/$defs/actionList" }
        ]
      }
    },
    "guardDefinitions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "when": { "$ref": "#/$defs/condition" }
        },
        "required": ["when"],
        "additionalProperties": false
      }
    },
    "delayDefinitions": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "number" },
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "duration": { "$ref": "#/$defs/duration" }
            },
            "required": ["duration"],
            "additionalProperties": false
          }
        ]
      }
    },
    "schemas": {
      "type": "object",
      "properties": {
        "context": { "$ref": "#/$defs/jsonSchema" },
        "events": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/eventPayloadSchema" }
        },
        "actions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "params": { "$ref": "#/$defs/jsonSchema" }
            },
            "required": ["params"],
            "additionalProperties": false
          }
        },
        "guards": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "params": { "$ref": "#/$defs/jsonSchema" }
            },
            "required": ["params"],
            "additionalProperties": false
          }
        },
        "actorSources": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "input": { "$ref": "#/$defs/jsonSchema" },
              "output": { "$ref": "#/$defs/jsonSchema" },
              "emitted": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/$defs/eventPayloadSchema"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "emitted": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/eventPayloadSchema" }
        },
        "input": { "$ref": "#/$defs/jsonSchema" },
        "output": { "$ref": "#/$defs/jsonSchema" },
        "meta": { "$ref": "#/$defs/jsonSchema" },
        "tags": { "$ref": "#/$defs/jsonSchema" },
        "children": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonSchema" }
        }
      },
      "additionalProperties": true
    },
    "stateNode": {
      "type": "object",
      "properties": {
        "@exprLang": { "type": "string" },
        "id": { "type": "string" },
        "key": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "atomic",
            "compound",
            "parallel",
            "final",
            "history",
            "choice"
          ]
        },
        "initial": { "$ref": "#/$defs/initial" },
        "states": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stateNode" }
        },
        "on": { "$ref": "#/$defs/transitionMap" },
        "onError": { "$ref": "#/$defs/transitionOrArray" },
        "after": { "$ref": "#/$defs/transitionMap" },
        "always": { "$ref": "#/$defs/transitionOrArray" },
        "choice": { "$ref": "#/$defs/choice" },
        "route": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "description": { "type": "string" },
                "reenter": { "type": "boolean" },
                "meta": { "type": "object" },
                "guard": { "type": "string" },
                "input": { "type": "object" }
              },
              "additionalProperties": false
            },
            { "$ref": "#/$defs/resolvable" }
          ]
        },
        "invoke": { "$ref": "#/$defs/invoke" },
        "entry": {
          "oneOf": [
            { "$ref": "#/$defs/actionList" },
            { "$ref": "#/$defs/action" }
          ]
        },
        "exit": {
          "oneOf": [
            { "$ref": "#/$defs/actionList" },
            { "$ref": "#/$defs/action" }
          ]
        },
        "timeout": { "$ref": "#/$defs/duration" },
        "onTimeout": { "$ref": "#/$defs/transitionOrArray" },
        "meta": { "type": "object" },
        "description": { "type": "string" },
        "history": { "type": "string", "enum": ["shallow", "deep"] },
        "target": { "type": "string" },
        "output": {},
        "input": {},
        "tags": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "context": { "type": "object" },
        "_scxmlDonedata": { "type": "object" },
        "version": { "type": "string" },
        "internalEvents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schemas": { "$ref": "#/$defs/schemas" },
        "actions": { "$ref": "#/$defs/actionDefinitions" },
        "guards": { "$ref": "#/$defs/guardDefinitions" },
        "actorSources": { "type": "object" },
        "delays": { "$ref": "#/$defs/delayDefinitions" }
      },
      "additionalProperties": true
    },
    "machine": { "$ref": "#/$defs/stateNode" }
  }
}
